{
  "_comment": "Missing optional fields are dropped entirely (no null keys)",
  "fields": [
    { "path": "full_name", "type": "string", "required": false },
    { "path": "headline", "type": "string", "required": false },
    { "path": "years_experience", "type": "number", "required": false },
    { "path": "skills", "from": "skills[].name", "type": "string[]", "required": false }
  ],
  "include_confidence": false,
  "include_provenance": false,
  "on_missing": "omit"
}
